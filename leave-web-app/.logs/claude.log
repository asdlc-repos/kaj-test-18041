    <>\n      {error && <div className=\"alert alert-error\">{error}</div>}\n      <div className=\"table-wrapper\">\n        <table>\n          <thead>\n            <tr>\n              <th>Type</th>\n              <th>Start Date</th>\n              <th>End Date</th>\n              <th>Reason</th>\n              <th>Status</th>\n              <th>Comment</th>\n              <th>Action</th>\n            </tr>\n          </thead>\n          <tbody>\n            {requests.map((req) => (\n              <tr key={req.id}>\n                <td>{req.type}</td>\n                <td>{formatDate(req.startDate)}</td>\n                <td>{formatDate(req.endDate)}</td>\n                <td>{req.reason}</td>\n                <td>\n                  <StatusBadge status={req.status} />\n                </td>\n                <td>{req.comment || '—'}</td>\n                <td>\n                  {req.status === 'pending' && (\n                    <button\n                      className=\"btn btn-danger btn-sm\"\n                      onClick={() => handleCancel(req.id)}\n                      disabled={cancelling === req.id}\n                    >\n                      {cancelling === req.id ? 'Cancelling…' : 'Cancel'}\n                    </button>\n                  )}\n                </td>\n              </tr>\n            ))}\n          </tbody>\n        </table>\n      </div>\n    </>\n  );\n}\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01QfmkUbq1HE2tvgsUupPanj","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01YbLCksj4qgUBKHzwoAhwZm","name":"Write","input":{"file_path":"/Users/kajendran/.asdlc/repos/default/kaj-test-18/leave-web-app/src/components/ManagerRequestList.tsx","content":"import React, { useState } from 'react';\nimport type { LeaveRequest } from '../api/leaveApi';\nimport { managerApi } from '../api/managerApi';\n\ninterface Props {\n  requests: LeaveRequest[];\n  onUpdate: (req: LeaveRequest) => void;\n}\n\nfunction formatDate(dateStr: string) {\n  try {\n    return new Date(dateStr).toLocaleDateString(undefined, {\n      year: 'numeric',\n      month: 'short',\n      day: 'numeric',\n    });\n  } catch {\n    return dateStr;\n  }\n}\n\ntype Action = 'approve' | 'reject';\n\ninterface ReviewModal {\n  requestId: string;\n  action: Action;\n  employeeName: string;\n}\n\nexport default function ManagerRequestList({ requests, onUpdate }: Props) {\n  const [modal, setModal] = useState<ReviewModal | null>(null);\n  const [comment, setComment] = useState('');\n  const [loading, setLoading] = useState(false);\n  const [error, setError] = useState('');\n\n  const openModal = (req: LeaveRequest, action: Action) => {\n    setModal({ requestId: req.id, action, employeeName: req.employeeName || req.employeeId });\n    setComment('');\n    setError('');\n  };\n\n  const closeModal = () => {\n    setModal(null);\n    setComment('');\n    setError('');\n  };\n\n  const handleReview = async () => {\n    if (!modal) return;\n    setLoading(true);\n    setError('');\n    try {\n      const fn =\n        modal.action === 'approve'\n          ? managerApi.approveRequest(modal.requestId, { comment })\n          : managerApi.rejectRequest(modal.requestId, { comment });\n      const updated = await fn;\n      onUpdate(updated);\n      closeModal();\n    } catch (err) {\n      setError(err instanceof Error ? err.message : 'Action failed. Please try again.');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const pending = requests.filter((r) => r.status === 'pending');\n  const reviewed = requests.filter((r) => r.status !== 'pending');\n\n  return (\n    <>\n      {/* Approve/Reject Modal */}\n      {modal && (\n        <div className=\"modal-overlay\" onClick={closeModal}>\n          <div className=\"modal\" onClick={(e) => e.stopPropagation()}>\n            <h3>\n              {modal.action === 'approve' ? 'Approve' : 'Reject'} Request\n            </h3>\n            <p style={{ color: '#555', marginBottom: '1rem', fontSize: '0.9rem' }}>\n              {modal.action === 'approve' ? 'Approving' : 'Rejecting'} leave request for{' '}\n              <strong>{modal.employeeName}</strong>.\n            </p>\n            {error && <div className=\"alert alert-error\">{error}</div>}\n            <div className=\"form-group\">\n              <label htmlFor=\"review-comment\">Comment (optional)</label>\n              <textarea\n                id=\"review-comment\"\n                value={comment}\n                onChange={(e: React.ChangeEvent<HTMLTextAreaElement>) => setComment(e.target.value)}\n                placeholder=\"Add a comment for the employee…\"\n                disabled={loading}\n              />\n            </div>\n            <div className=\"modal-actions\">\n              <button className=\"btn btn-secondary\" onClick={closeModal} disabled={loading}>\n                Cancel\n              </button>\n              <button\n                className={`btn ${modal.action === 'approve' ? 'btn-success' : 'btn-danger'}`}\n                onClick={handleReview}\n                disabled={loading}\n              >\n                {loading\n                  ? 'Processing…'\n                  : modal.action === 'approve'\n                  ? 'Approve'\n                  : 'Reject'}\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* Pending requests */}\n      <div className=\"card\">\n        <div className=\"card-title\">Pending Requests ({pending.length})</div>\n        {pending.length === 0 ? (\n          <div className=\"empty-state\">\n            <p>No pending requests to review.</p>\n          </div>\n        ) : (\n          <div className=\"table-wrapper\">\n            <table>\n              <thead>\n                <tr>\n                  <th>Employee</th>\n                  <th>Type</th>\n                  <th>Start Date</th>\n                  <th>End Date</th>\n                  <th>Reason</th>\n                  <th>Actions</th>\n                </tr>\n              </thead>\n              <tbody>\n                {pending.map((req) => (\n                  <tr key={req.id}>\n                    <td>{req.employeeName || req.employeeId}</td>\n                    <td>{req.type}</td>\n                    <td>{formatDate(req.startDate)}</td>\n                    <td>{formatDate(req.endDate)}</td>\n                    <td>{req.reason}</td>\n                    <td>\n                      <div style={{ display: 'flex', gap: '0.5rem' }}>\n                        <button\n                          className=\"btn btn-success btn-sm\"\n                          onClick={() => openModal(req, 'approve')}\n                        >\n                          Approve\n                        </button>\n                        <button\n                          className=\"btn btn-danger btn-sm\"\n                          onClick={() => openModal(req, 'reject')}\n                        >\n                          Reject\n                        </button>\n                      </div>\n                    </td>\n                  </tr>\n                ))}\n              </tbody>\n            </table>\n          </div>\n        )}\n      </div>\n\n      {/* Reviewed requests */}\n      {reviewed.length > 0 && (\n        <div className=\"card\">\n          <div className=\"card-title\">Reviewed Requests</div>\n          <div className=\"table-wrapper\">\n            <table>\n              <thead>\n                <tr>\n                  <th>Employee</th>\n                  <th>Type</th>\n                  <th>Start Date</th>\n                  <th>End Date</th>\n                  <th>Status</th>\n                  <th>Comment</th>\n                </tr>\n              </thead>\n              <tbody>\n                {reviewed.map((req) => (\n                  <tr key={req.id}>\n                    <td>{req.employeeName || req.employeeId}</td>\n                    <td>{req.type}</td>\n                    <td>{formatDate(req.startDate)}</td>\n                    <td>{formatDate(req.endDate)}</td>\n                    <td>\n                      <span className={`badge badge-${req.status}`}>{req.status}</span>\n                    </td>\n                    <td>{req.comment || '—'}</td>\n                  </tr>\n                ))}\n              </tbody>\n            </table>\n          </div>\n        </div>\n      )}\n    </>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":958,"cache_read_input_tokens":31027,"cache_creation":{"ephemeral_5m_input_tokens":958,"ephemeral_1h_input_tokens":0},"output_tokens":63,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"755a9b6e-46f8-4ab7-8b0d-958937029f65","uuid":"a0b3e414-4dbc-4fef-bcfc-1ea82c6aaf51"}
