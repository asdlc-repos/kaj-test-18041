{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01U4uaYzkAN3V5UJCFUEHo9D","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01J77YA5Rx9EzTjHzwxcgbhT","name":"Write","input":{"file_path":"/Users/kajendran/.asdlc/repos/default/kaj-test-18/leave-web-app/src/App.tsx","content":"import { BrowserRouter, Routes, Route, Navigate, NavLink } from 'react-router-dom';\nimport { AuthProvider, useAuth } from './contexts/AuthContext';\nimport LoginPage from './pages/LoginPage';\nimport EmployeeDashboard from './pages/EmployeeDashboard';\nimport ManagerDashboard from './pages/ManagerDashboard';\n\nfunction RequireAuth({ children }: { children: React.ReactNode }) {\n  const { isAuthenticated } = useAuth();\n  return isAuthenticated ? <>{children}</> : <Navigate to=\"/login\" replace />;\n}\n\nfunction RequireRole({ role, children }: { role: string; children: React.ReactNode }) {\n  const { user } = useAuth();\n  if (!user) return <Navigate to=\"/login\" replace />;\n  if (user.role !== role) return <Navigate to={user.role === 'manager' ? '/manager' : '/dashboard'} replace />;\n  return <>{children}</>;\n}\n\nfunction Header() {\n  const { user, logout, isAuthenticated } = useAuth();\n\n  if (!isAuthenticated) return null;\n\n  return (\n    <header className=\"app-header\">\n      <h1>Leave Management System</h1>\n      <nav>\n        {user?.role === 'employee' && (\n          <NavLink to=\"/dashboard\" className={({ isActive }) => `nav-link${isActive ? ' active' : ''}`}>\n            My Dashboard\n          </NavLink>\n        )}\n        {user?.role === 'manager' && (\n          <>\n            <NavLink to=\"/manager\" className={({ isActive }) => `nav-link${isActive ? ' active' : ''}`}>\n              Manager Dashboard\n            </NavLink>\n            <NavLink to=\"/dashboard\" className={({ isActive }) => `nav-link${isActive ? ' active' : ''}`}>\n              My Leaves\n            </NavLink>\n          </>\n        )}\n        <button className=\"btn-logout\" onClick={logout}>\n          Sign Out\n        </button>\n      </nav>\n    </header>\n  );\n}\n\nfunction AppRoutes() {\n  const { user } = useAuth();\n\n  return (\n    <>\n      <Header />\n      <Routes>\n        <Route path=\"/login\" element={<LoginPage />} />\n\n        <Route\n          path=\"/dashboard\"\n          element={\n            <RequireAuth>\n              <EmployeeDashboard />\n            </RequireAuth>\n          }\n        />\n\n        <Route\n          path=\"/manager\"\n          element={\n            <RequireRole role=\"manager\">\n              <ManagerDashboard />\n            </RequireRole>\n          }\n        />\n\n        {/* Default redirect */}\n        <Route\n          path=\"/\"\n          element={\n            user\n              ? <Navigate to={user.role === 'manager' ? '/manager' : '/dashboard'} replace />\n              : <Navigate to=\"/login\" replace />\n          }\n        />\n\n        <Route path=\"*\" element={<Navigate to=\"/\" replace />} />\n      </Routes>\n    </>\n  );\n}\n\nexport default function App() {\n  return (\n    <BrowserRouter>\n      <AuthProvider>\n        <AppRoutes />\n      </AuthProvider>\n    </BrowserRouter>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":598,"cache_read_input_tokens":34629,"cache_creation":{"ephemeral_5m_input_tokens":598,"ephemeral_1h_input_tokens":0},"output_tokens":61,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"755a9b6e-46f8-4ab7-8b0d-958937029f65","uuid":"11d8ff06-4337-4c36-8790-a3ac6cf0d712"}
