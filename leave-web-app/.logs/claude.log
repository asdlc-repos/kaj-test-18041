odal.requestId, { comment })\n          : managerApi.rejectRequest(modal.requestId, { comment });\n      const updated = await fn;\n      onUpdate(updated);\n      closeModal();\n    } catch (err) {\n      setError(err instanceof Error ? err.message : 'Action failed. Please try again.');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const pending = requests.filter((r) => r.status === 'pending');\n  const reviewed = requests.filter((r) => r.status !== 'pending');\n\n  return (\n    <>\n      {/* Approve/Reject Modal */}\n      {modal && (\n        <div className=\"modal-overlay\" onClick={closeModal}>\n          <div className=\"modal\" onClick={(e) => e.stopPropagation()}>\n            <h3>\n              {modal.action === 'approve' ? 'Approve' : 'Reject'} Request\n            </h3>\n            <p style={{ color: '#555', marginBottom: '1rem', fontSize: '0.9rem' }}>\n              {modal.action === 'approve' ? 'Approving' : 'Rejecting'} leave request for{' '}\n              <strong>{modal.employeeName}</strong>.\n            </p>\n            {error && <div className=\"alert alert-error\">{error}</div>}\n            <div className=\"form-group\">\n              <label htmlFor=\"review-comment\">Comment (optional)</label>\n              <textarea\n                id=\"review-comment\"\n                value={comment}\n                onChange={(e: React.ChangeEvent<HTMLTextAreaElement>) => setComment(e.target.value)}\n                placeholder=\"Add a comment for the employee…\"\n                disabled={loading}\n              />\n            </div>\n            <div className=\"modal-actions\">\n              <button className=\"btn btn-secondary\" onClick={closeModal} disabled={loading}>\n                Cancel\n              </button>\n              <button\n                className={`btn ${modal.action === 'approve' ? 'btn-success' : 'btn-danger'}`}\n                onClick={handleReview}\n                disabled={loading}\n              >\n                {loading\n                  ? 'Processing…'\n                  : modal.action === 'approve'\n                  ? 'Approve'\n                  : 'Reject'}\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* Pending requests */}\n      <div className=\"card\">\n        <div className=\"card-title\">Pending Requests ({pending.length})</div>\n        {pending.length === 0 ? (\n          <div className=\"empty-state\">\n            <p>No pending requests to review.</p>\n          </div>\n        ) : (\n          <div className=\"table-wrapper\">\n            <table>\n              <thead>\n                <tr>\n                  <th>Employee</th>\n                  <th>Type</th>\n                  <th>Start Date</th>\n                  <th>End Date</th>\n                  <th>Reason</th>\n                  <th>Actions</th>\n                </tr>\n              </thead>\n              <tbody>\n                {pending.map((req) => (\n                  <tr key={req.id}>\n                    <td>{req.employeeName || req.employeeId}</td>\n                    <td>{req.type}</td>\n                    <td>{formatDate(req.startDate)}</td>\n                    <td>{formatDate(req.endDate)}</td>\n                    <td>{req.reason}</td>\n                    <td>\n                      <div style={{ display: 'flex', gap: '0.5rem' }}>\n                        <button\n                          className=\"btn btn-success btn-sm\"\n                          onClick={() => openModal(req, 'approve')}\n                        >\n                          Approve\n                        </button>\n                        <button\n                          className=\"btn btn-danger btn-sm\"\n                          onClick={() => openModal(req, 'reject')}\n                        >\n                          Reject\n                        </button>\n                      </div>\n                    </td>\n                  </tr>\n                ))}\n              </tbody>\n            </table>\n          </div>\n        )}\n      </div>\n\n      {/* Reviewed requests */}\n      {reviewed.length > 0 && (\n        <div className=\"card\">\n          <div className=\"card-title\">Reviewed Requests</div>\n          <div className=\"table-wrapper\">\n            <table>\n              <thead>\n                <tr>\n                  <th>Employee</th>\n                  <th>Type</th>\n                  <th>Start Date</th>\n                  <th>End Date</th>\n                  <th>Status</th>\n                  <th>Comment</th>\n                </tr>\n              </thead>\n              <tbody>\n                {reviewed.map((req) => (\n                  <tr key={req.id}>\n                    <td>{req.employeeName || req.employeeId}</td>\n                    <td>{req.type}</td>\n                    <td>{formatDate(req.startDate)}</td>\n                    <td>{formatDate(req.endDate)}</td>\n                    <td>\n                      <span className={`badge badge-${req.status}`}>{req.status}</span>\n                    </td>\n                    <td>{req.comment || '—'}</td>\n                  </tr>\n                ))}\n              </tbody>\n            </table>\n          </div>\n        </div>\n      )}\n    </>\n  );\n}\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_0134mJZ5PMj1oyD2dVTH3rQ2","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TcnL76J1ewsyLUdPz9eiVy","name":"Write","input":{"file_path":"/Users/kajendran/.asdlc/repos/default/kaj-test-18/leave-web-app/src/pages/EmployeeDashboard.tsx","content":"import { useEffect, useState } from 'react';\nimport { leaveApi } from '../api/leaveApi';\nimport type { LeaveRequest } from '../api/leaveApi';\nimport LeaveBalance from '../components/LeaveBalance';\nimport LeaveRequestForm from '../components/LeaveRequestForm';\nimport RequestList from '../components/RequestList';\nimport { useAuth } from '../contexts/AuthContext';\n\nexport default function EmployeeDashboard() {\n  const { user } = useAuth();\n  const [requests, setRequests] = useState<LeaveRequest[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState('');\n\n  useEffect(() => {\n    leaveApi\n      .getMyRequests()\n      .then(setRequests)\n      .catch((err: Error) => setError(err.message))\n      .finally(() => setLoading(false));\n  }, []);\n\n  const handleNewRequest = (req: LeaveRequest) => {\n    setRequests((prev) => [req, ...prev]);\n  };\n\n  const handleUpdate = (updated: LeaveRequest) => {\n    setRequests((prev) => prev.map((r) => (r.id === updated.id ? updated : r)));\n  };\n\n  return (\n    <div className=\"main-content\">\n      <div className=\"dashboard-header\">\n        <h2>My Leave Dashboard</h2>\n        <span className=\"user-info\">Welcome, {user?.name}</span>\n      </div>\n\n      <LeaveBalance />\n\n      <LeaveRequestForm onSuccess={handleNewRequest} />\n\n      <div className=\"card\">\n        <div className=\"card-title\">My Requests</div>\n        {loading ? (\n          <div className=\"loading\">\n            <div className=\"spinner\" />\n            Loading requests…\n          </div>\n        ) : error ? (\n          <div className=\"alert alert-error\">Failed to load requests: {error}</div>\n        ) : (\n          <RequestList requests={requests} onUpdate={handleUpdate} />\n        )}\n      </div>\n    </div>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1962,"cache_read_input_tokens":31985,"cache_creation":{"ephemeral_5m_input_tokens":1962,"ephemeral_1h_input_tokens":0},"output_tokens":59,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"755a9b6e-46f8-4ab7-8b0d-958937029f65","uuid":"7d49d4f3-29d4-4283-aad8-b2f811f11ec9"}
